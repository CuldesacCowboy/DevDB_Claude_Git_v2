# Copy this file to .env and fill in your values.
# Never commit .env to git.

DATABRICKS_HOST=your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token
# Optional -- defaults to the project warehouse if omitted
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/7228fe0366c2e8a0

# Postgres (local) -- used by the simulation engine
PG_USER=postgres
PG_PASSWORD=
PG_PORT=5432
